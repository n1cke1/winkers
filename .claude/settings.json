{
  "permissions": {
    "allow": [
      "mcp__winkers__*",
      "Bash(.venv/Scripts/python -c \":*)",
      "Bash(gh run:*)",
      "Bash(gh issue:*)",
      "Bash(.venv/Scripts/pytest tests/ -v -x -k \"init or install or claude\")",
      "Bash(gh api:*)",
      "Read(//c/Users/NP/.ssh/**)",
      "Bash(ssh -o StrictHostKeyChecking=no root@***REDACTED-VPS*** \"echo OK\")",
      "Bash(ssh root@***REDACTED-VPS*** \"code tunnel --accept-server-license-terms 2>&1 &\")",
      "Bash(ssh -t root@***REDACTED-VPS*** \"timeout 10 code tunnel --accept-server-license-terms 2>&1 || true\")",
      "Bash(ssh root@***REDACTED-VPS*** \"code tunnel status 2>&1; code tunnel rename winkers-vps 2>&1 || true\")",
      "Bash(ssh root@***REDACTED-VPS***:*)",
      "Bash(ssh -t root@***REDACTED-VPS*** \"timeout 15 claude login 2>&1\")",
      "Bash(git fetch:*)",
      "Bash(gh repo:*)"
    ]
  },
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git add -A && git diff --cached --quiet || git commit -m 'wip: auto-commit from Claude session' --no-verify",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/NP/AppData/Local/Programs/Python/Python313/Scripts/winkers.EXE record --hook",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
