{
  "permissions": {
    "allow": [
      "mcp__winkers__*",
      "Bash(.venv/Scripts/python -c \":*)",
      "Bash(gh run:*)",
      "Bash(gh issue:*)",
      "Bash(.venv/Scripts/pytest tests/ -v -x -k \"init or install or claude\")",
      "Bash(gh api:*)"
    ]
  },
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git add -A && git diff --cached --quiet || git commit -m 'wip: auto-commit from Claude session' --no-verify",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/NP/AppData/Local/Programs/Python/Python313/Scripts/winkers.EXE record --hook",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
